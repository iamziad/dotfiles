command=$SCRIPT_DIR/$BLOCK_NAME
separator_block_width=15
markup=none
color=#e7feff

[mediaplayer]
command=$SCRIPT_DIR/mediaplayer/mediaplayer
label=♪
color=#7fffd4
instance=spotify
interval=5
signal=10

[bandwidth]
command=INLABEL=' ' OUTLABEL=' ' $SCRIPT_DIR/bandwidth/bandwidth
markup=pango
interval=5
# INTERFACE=enp3s0
# TREAT_UNKNOWN_AS_UP=0

[memory]
command=$SCRIPT_DIR/memory/memory
label= MEM:
instance=mem
separator=true
interval=30

[disk]
label=HOME
#DIR=/mnt/data
interval=30

[iface]
#IFACE=wlan0
color=#00FF00
interval=10
separator=false

[wifi]
#INTERFACE=wlp3s0
label=wifi:
interval=10
separator=false

[cpu_usage]
command=LABEL='  CPU: ' T_WARN=65 T_CRIT=80 COLOR_NORMAL='#EBDBB2' COLOR_WARN='#FFFC00' COLOR_CRIT='#FF0000' $SCRIPT_DIR/cpu_usage/cpu_usage
interval=10
separator=false

[temperature]
command=T_WARN=60 T_CRIT=70 $SCRIPT_DIR/temperature/temperature
interval=10

[load_average]
label=LOAD
interval=10

[battery]
label=BAT
#label=⚡
interval=30

# [redshift_service]
# command=UNIT_NAME=redshift.service USER_UNIT=true ACTIVE_COLOR="#09c609" INACTIVE_COLOR=orange FAILED_COLOR=red $SCRIPT_DIR/systemd_unit/systemd_unit
# markup=pango
# label=redshift:
# interval=30

[volume]
command=LABEL='  ' $SCRIPT_DIR/volume/volume
interval=once
signal=10
#STEP=5%

[time]
command=date '+%y-%m-%d, %a %H:%M'
interval=5

[xkb_layout]
command=font=monospace font_weight=regular $SCRIPT_DIR/xkb_layout/xkb_layout
interval=persist
markup=pango
