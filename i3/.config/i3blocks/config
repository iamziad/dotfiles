color=#c0c0c0
instance=spotify
interval=5
signal=10

[bandwidth]
command=INLABEL='’äé ' OUTLABEL='’äā ' TREAT_UNKNOWN_AS_UP=0 $SCRIPT_DIR/bandwidth/bandwidth
markup=pango
interval=5
# INTERFACE=enp3s0
# TREAT_UNKNOWN_AS_UP=0

[memory]
command=$SCRIPT_DIR/memory/memory
label=MEM:
instance=mem
separator=true
interval=10

[disk]
label=HOME
#DIR=/mnt/data
interval=30

[iface]
#IFACE=wlan0
color=#00FF00
interval=10
separator=false

[wifi]
#INTERFACE=wlp3s0
label=wifi:
interval=10
separator=false

[cpu_usage]
command=LABEL='CPU: ' T_WARN=65 T_CRIT=80 COLOR_NORMAL='#EBDBB2' COLOR_WARN='#FFFC00' COLOR_CRIT='#FF0000' $SCRIPT_DIR/cpu_usage/cpu_usage
interval=10
separator=false

[temperature]
command=T_WARN=60 T_CRIT=70 $SCRIPT_DIR/temperature/temperature
interval=10

[load_average]
label=LOAD
interval=10

[battery]
label=BAT
#label=ŌÜĪ
interval=30

